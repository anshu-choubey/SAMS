# SAMS Backend - Production Environment Variables
# Copy this file to .env and update with your production values

# Database Configuration
MYSQL_HOST=sams-mysql-server.mysql.database.azure.com
MYSQL_USER=samsadmin@sams-mysql-server
MYSQL_PASSWORD=YourSecurePassword123!
MYSQL_DATABASE=sams_db
MYSQL_PORT=3306
MYSQL_SSL=PREFERRED

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters

# Firebase Configuration (for push notifications)
FIREBASE_SERVER_KEY=your-firebase-server-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://sams-backend.azurewebsites.net

# CORS Settings (comma-separated allowed origins)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://sams-app.com

# File Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Face Recognition Settings
FACE_CONFIDENCE_THRESHOLD=75
GPS_PROXIMITY_RADIUS=50

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Logging
LOG_LEVEL=error
LOG_FILE=/var/log/sams-backend.log

# Azure Application Insights (optional)
APPLICATION_INSIGHTS_KEY=your-app-insights-key